{
  "instructions": [
    "~/.config/opencode/rules/*.md",
    ".opencode/rules/*.md",
    ".opencode/learnings/LEARNINGS.md"
  ],
  "plugin": ["opencode-ponytail", "opencode-ignore"],
  "permission": {
    "bash": {
      "cat *": "deny",
      "/usr/bin/cat *": "deny",
      "/bin/cat *": "deny",
      "head *": "deny",
      "tail *": "deny",
      "less *": "deny",
      "more *": "deny",
      "strings *": "deny",
      "xxd *": "deny",
      "base64 *": "deny",
      "od *": "deny",
      "tac *": "deny",
      "nl *": "deny",
      "pr *": "deny",
      "fold *": "deny",
      "expand *": "deny",
      "uniq *": "deny",
      "sort *": "deny",
      "rev *": "deny",
      "cut *": "deny",
      "paste *": "deny"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "provider": {
    "openrouter": {
      "npm": "@openrouter/ai-sdk-provider",
      "name": "OpenRouter",
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "whitelist": [
        "deepseek/deepseek-v4-flash",
        "deepseek/deepseek-v4-pro",
        "tencent/hy3-preview",
        "xiaomi/mimo-v2.5",
        "minimax/minimax-m3"
      ],
      "models": {}
    },
    "opencode": {
      "name": "OpenCode",
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "whitelist": [
        "gemini-3-flash",
        "deepseek-v4-flash"
      ],
      "models": {}
    }
  },
  "model": "openrouter/deepseek/deepseek-v4-flash"
}
