{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#0d0f31",
    "bgPanel": "#070825",
    "bgElement": "#12143d",
    "text": "#f1f1f1",
    "textMuted": "#4E5666",
    "cyan": "#46BDFF",
    "cyanSoft": "#59E1E3",
    "green": "#B3F361",
    "yellow": "#FFEA16",
    "orange": "#fcee54",
    "red": "#FF407B",
    "magenta": "#FF16B0",
    "white": "#ffffff"
  },
  "theme": {
    "primary": { "dark": "cyan", "light": "cyan" },
    "secondary": { "dark": "cyanSoft", "light": "cyanSoft" },
    "accent": { "dark": "magenta", "light": "magenta" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "yellow", "light": "yellow" },
    "success": { "dark": "green", "light": "green" },
    "info": { "dark": "cyan", "light": "cyan" },
    "text": { "dark": "text", "light": "bg" },
    "textMuted": { "dark": "textMuted", "light": "textMuted" },
    "background": { "dark": "bg", "light": "white" },
    "backgroundPanel": { "dark": "bgPanel", "light": "white" },
    "backgroundElement": { "dark": "bgElement", "light": "text" },
    "border": { "dark": "bgElement", "light": "textMuted" },
    "borderActive": { "dark": "textMuted", "light": "textMuted" },
    "borderSubtle": { "dark": "bgPanel", "light": "textMuted" },
    "diffAdded": { "dark": "green", "light": "green" },
    "diffRemoved": { "dark": "red", "light": "red" },
    "diffContext": { "dark": "textMuted", "light": "textMuted" },
    "diffHunkHeader": { "dark": "textMuted", "light": "textMuted" },
    "diffHighlightAdded": { "dark": "green", "light": "green" },
    "diffHighlightRemoved": { "dark": "red", "light": "red" },
    "diffAddedBg": { "dark": "#13203a", "light": "#e8f5d8" },
    "diffRemovedBg": { "dark": "#2a1030", "light": "#fde8ef" },
    "diffContextBg": { "dark": "bgPanel", "light": "white" },
    "diffLineNumber": { "dark": "bgElement", "light": "textMuted" },
    "diffAddedLineNumberBg": { "dark": "#13203a", "light": "#e8f5d8" },
    "diffRemovedLineNumberBg": { "dark": "#2a1030", "light": "#fde8ef" },
    "markdownText": { "dark": "text", "light": "bg" },
    "markdownHeading": { "dark": "cyan", "light": "cyan" },
    "markdownLink": { "dark": "cyanSoft", "light": "cyanSoft" },
    "markdownLinkText": { "dark": "magenta", "light": "magenta" },
    "markdownCode": { "dark": "green", "light": "green" },
    "markdownBlockQuote": { "dark": "textMuted", "light": "textMuted" },
    "markdownEmph": { "dark": "orange", "light": "orange" },
    "markdownStrong": { "dark": "yellow", "light": "yellow" },
    "markdownHorizontalRule": { "dark": "textMuted", "light": "textMuted" },
    "markdownListItem": { "dark": "cyan", "light": "cyan" },
    "markdownListEnumeration": { "dark": "magenta", "light": "magenta" },
    "markdownImage": { "dark": "cyanSoft", "light": "cyanSoft" },
    "markdownImageText": { "dark": "magenta", "light": "magenta" },
    "markdownCodeBlock": { "dark": "text", "light": "bg" },
    "syntaxComment": { "dark": "textMuted", "light": "textMuted" },
    "syntaxKeyword": { "dark": "magenta", "light": "magenta" },
    "syntaxFunction": { "dark": "cyan", "light": "cyan" },
    "syntaxVariable": { "dark": "cyanSoft", "light": "cyanSoft" },
    "syntaxString": { "dark": "green", "light": "green" },
    "syntaxNumber": { "dark": "orange", "light": "orange" },
    "syntaxType": { "dark": "yellow", "light": "yellow" },
    "syntaxOperator": { "dark": "magenta", "light": "magenta" },
    "syntaxPunctuation": { "dark": "text", "light": "bg" }
  }
}
