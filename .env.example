# Copy to .env and edit, or export these before running ./install.sh
#
#   cp .env.example .env

# Models (OpenRouter IDs without the openrouter/ prefix)
OPENZED_MODEL=deepseek/deepseek-v4-flash

# Install paths
OPENZED_BIN_DIR=$HOME/.local/bin

# Cloud providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
