# Copy to .env and edit, or export these before running ./install.sh
#
#   cp .env.example .env

# === API Keys ===
# Set OPENROUTER_API_KEY for OpenRouter models (deepseek, gemini, etc.)
#   Leave empty → OpenCode uses its built-in FREE models instead.
OPENROUTER_API_KEY=
# Set OPENCODE_API_KEY to unlock all OpenCode Zen models (optional).
#   Leave empty → only OpenCode's free models are available.
OPENCODE_API_KEY=

# === OpenCode Models ===
# Model IDs (without the openrouter/ prefix).
# Only used when OPENROUTER_API_KEY is set.
# When OPENROUTER_API_KEY is empty, OpenCode automatically selects
# its best free model (claude-sonnet-4-5).
OPENZED_MODEL=deepseek/deepseek-v4-flash
OPENZED_SMALL_MODEL=deepseek/deepseek-v4-flash

# === Install ===
OPENZED_BIN_DIR=$HOME/.local/bin

# === OpenRouter (optional) ===
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
