# Copy to .env and edit, or export these before running ./install.sh
#
#   cp .env.example .env

# Local models
OPENZED_MODEL=gemma4:latest
OPENZED_SMALL_MODEL=qwen3.5:9b

# Install paths
OPENZED_BIN_DIR=$HOME/.local/bin
OPENZED_OLLAMA_URL=http://localhost:11434/v1

# Optional cloud providers (leave blank to use local Ollama only)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OLLAMA_API_KEY=
OPENZED_OLLAMA_CLOUD_URL=https://ollama.com/v1
