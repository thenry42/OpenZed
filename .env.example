# cp .env.example .env   then ./install.sh
# See README.md "Configuration" for details on each var.

# Required for OpenRouter models (deepseek, gemini, etc.).
OPENROUTER_API_KEY=
# API key for OpenCode-provided models (optional).
OPENCODE_API_KEY=

# Primary coding model (OpenRouter). Override before install.
BASE_MODEL=deepseek/deepseek-v4-flash

# Install target directory.
OPENZED_BIN_DIR=$HOME/.local/bin

# Override for OpenRouter-compatible endpoints (optional).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
